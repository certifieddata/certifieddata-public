{
  "name": "@certifieddata/embed",
  "version": "0.1.0",
  "description": "CertifiedData.io verification badge and trust widget — TypeScript module",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node -e \"process.exit(0)\"",
    "lint": "node -e \"process.exit(0)\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
