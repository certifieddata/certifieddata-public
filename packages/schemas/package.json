{
  "name": "@certifieddata/schemas",
  "version": "0.1.0",
  "description": "Public certificate schema definitions, validators, and version lifecycle metadata for CertifiedData.io",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "!dist/*.test.js", "!dist/*.test.d.ts", "!dist/*.test.js.map", "!dist/*.test.d.ts.map", "json", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/index.test.js",
    "lint": "node -e \"process.exit(0)\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["certifieddata", "schema", "certificate", "synthetic-data", "governance"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/certifieddata/certifieddata-public.git",
    "directory": "packages/schemas"
  }
}
