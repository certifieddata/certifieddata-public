{
  "name": "@certifieddata/verify",
  "version": "0.1.0",
  "description": "Verify CertifiedData.io certificate manifests — Ed25519 signature + payload canonicalization",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "!dist/*.test.js", "!dist/*.test.d.ts", "!dist/*.test.js.map", "!dist/*.test.d.ts.map", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node --test dist/verify.test.js",
    "lint": "node -e \"process.exit(0)\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "json-stable-stringify": "^1.1.1"
  },
  "devDependencies": {
    "@types/json-stable-stringify": "^1.0.36",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["certifieddata", "certificate", "verify", "ed25519", "synthetic-data"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/certifieddata/certifieddata-public.git",
    "directory": "packages/verify"
  }
}
